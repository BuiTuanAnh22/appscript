const CFG = {
  TASKS_SHEET: 'Tasks',
  ARCHIVE_SHEET: 'Archive',
  SETTINGS_SHEET: 'Settings',
  HEADER_ROW: 1,

  STATUS_UNDONE: 'Undone',
  STATUS_DONE: 'Done',

  PRIORITIES: ['Low', 'Medium', 'High', 'Urgent'],
  STATUSES: ['Undone', 'Done']
};

const COL = {
  ID: 1,             // A
  TASK: 2,           // B
  CATEGORY: 3,       // C
  OWNER_EMAIL: 4,    // D
  DUE_DATE: 5,       // E
  PRIORITY: 6,       // F
  STATUS: 7,         // G
  REMINDER_SENT: 8,  // H
  LAST_REMINDER: 9,  // I
  NOTES: 10,         // J
  CREATED_AT: 11,    // K
  COMPLETED_AT: 12   // L
};

/**
 * Opens custom menu when spreadsheet is opened.
 * This does NOT run on every edit.
 */

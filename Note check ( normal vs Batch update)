/**
 * Sets up Settings sheet.
 */
function setupSettingsSheet_(sheet) {
  const values = [
    ['Default Reminder Email', 'your@email.com'],
    ['Daily Reminder Hour', '8']
  ];

  sheet.clear();
  sheet.getRange(1, 1, values.length, 2).setValues(values);
  sheet.autoResizeColumns(1, 2);
}

/**
 * Applies dropdown validation to Priority and Status columns.
 */
function setupDropdowns_(sheet) {
  const maxRows = Math.max(sheet.getMaxRows(), 1000);

  const priorityRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(CFG.PRIORITIES, true)
    .setAllowInvalid(false)
    .build();

  const statusRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(CFG.STATUSES, true)
    .setAllowInvalid(false)
    .build();

  sheet.getRange(2, COL.PRIORITY, maxRows - 1).setDataValidation(priorityRule);
  sheet.getRange(2, COL.STATUS, maxRows - 1).setDataValidation(statusRule);
}

/**
 * Applies conditional formatting:
 * - Urgent + Undone = red
 * - Overdue + Undone = yellow
 * - Due today + Undone = light green
 */
function setupConditionalFormatting() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CFG.TASKS_SHEET);
  if (!sheet) return;

  const range = sheet.getRange('A2:L1000');
  const rules = [];

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=AND($F2="Urgent",$G2="Undone")')
      .setBackground('#f4cccc')
      .setBold(true)
      .setRanges([range])
      .build()
  );

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=AND($E2<>"",$E2<TODAY(),$G2="Undone")')
      .setBackground('#fff2cc')
      .setRanges([range])
      .build()
  );

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied('=AND($E2=TODAY(),$G2="Undone")')
      .setBackground('#d9ead3')
      .setRanges([range])
      .build()
  );

  sheet.setConditionalFormatRules(rules);
}

/**
 * Reads Settings sheet.
 */
function getSettings_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CFG.SETTINGS_SHEET);
  if (!sheet) throw new Error('Settings sheet not found.');

  const values = sheet.getRange(1, 1, sheet.getLastRow(), 2).getValues();
  const map = {};

  values.forEach(([key, value]) => {
    if (key) map[String(key).trim()] = value;
  });

  return {
    defaultEmail: String(map['Default Reminder Email'] || '').trim(),
    dailyHour: Number(map['Daily Reminder Hour'] || 8)
  };
}

/**
 * Adds Task ID and Created At to existing rows that have a task but are missing those fields.
 * Run this manually from the menu.
 */
function fillMissingTaskMetadata() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CFG.TASKS_SHEET);
  if (!sheet) throw new Error('Tasks sheet not found.');

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  const data = sheet.getRange(2, 1, lastRow - 1, COL.COMPLETED_AT).getValues();
  const now = new Date();

  for (let i = 0; i < data.length; i++) {
    const rowNumber = i + 2;
    const row = data[i];

    const task = row[COL.TASK - 1];
    const id = row[COL.ID - 1];
    const status = row[COL.STATUS - 1];
    const createdAt = row[COL.CREATED_AT - 1];

    if (!task) continue;

    if (!id) {
      sheet.getRange(rowNumber, COL.ID).setValue(createTaskId_());
    }

    if (!createdAt) {
      sheet.getRange(rowNumber, COL.CREATED_AT).setValue(now);
    }

    if (!status) {
      sheet.getRange(rowNumber, COL.STATUS).setValue(CFG.STATUS_UNDONE);
    }
  }

  SpreadsheetApp.getUi().alert('Missing Task ID / Created At / Status filled.');
}

/**
 * Creates a unique task ID.
 */
function createTaskId_() {
  return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyyMMdd-HHmmss');
}

/**
 * Sends one daily summary email with all undone tasks.
 * This runs only when:
 * - you click it manually, or
 * - the daily trigger runs
 */
function sendDailySummaryEmail() {
  const settings = getSettings_();
  const email = settings.defaultEmail;

  if (!email) {
    throw new Error('Default Reminder Email is blank in Settings sheet.');
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CFG.TASKS_SHEET);
  if (!sheet) throw new Error('Tasks sheet not found.');

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  const data = sheet.getRange(2, 1, lastRow - 1, COL.COMPLETED_AT).getValues();

  const urgent = [];
  const high = [];
  const others = [];
  const now = new Date();

  for (let i = 0; i < data.length; i++) {
    const row = data[i];
    const rowNumber = i + 2;

    const task = row[COL.TASK - 1];
    const category = row[COL.CATEGORY - 1];
    const ownerEmail = row[COL.OWNER_EMAIL - 1];
    const dueDate = row[COL.DUE_DATE - 1];
    const priority = row[COL.PRIORITY - 1];
    const status = row[COL.STATUS - 1];
    const notes = row[COL.NOTES - 1];

    if (!task || status !== CFG.STATUS_UNDONE) continue;

    const taskLine = buildTaskLine_(task, category, ownerEmail, dueDate, priority, notes);

    if (priority === 'Urgent') {
      urgent.push(taskLine);
    } else if (priority === 'High') {
      high.push(taskLine);
    } else {
      others.push(taskLine);
    }

    sheet.getRange(rowNumber, COL.REMINDER_SENT).setValue('Yes');
    sheet.getRange(rowNumber, COL.LAST_REMINDER).setValue(now);
  }

  if (urgent.length === 0 && high.length === 0 && others.length === 0) {
    return;
  }

  const subject = `Task Summary: ${urgent.length} urgent, ${urgent.length + high.length + others.length} total undone`;
  const body = buildEmailBody_(urgent, high, others);

  const remainingQuota = MailApp.getRemainingDailyQuota();
  if (remainingQuota < 1) {
    throw new Error('No email quota remaining today.');
  }

  MailApp.sendEmail(email, subject, body);
}

/**
 * Builds one task line for email body.
 */
function buildTaskLine_(task, category, ownerEmail, dueDate, priority, notes) {
  const parts = [];

  parts.push(`Task: ${task}`);

  if (dueDate) {
    parts.push(`Due: ${formatDate_(dueDate)}`);
  }

  if (priority) {
    parts.push(`Priority: ${priority}`);
  }

  if (category) {
    parts.push(`Category: ${category}`);
  }

  if (ownerEmail) {
    parts.push(`Owner: ${ownerEmail}`);
  }

  if (notes) {
    parts.push(`Notes: ${notes}`);
  }

  return `- ${parts.join(' | ')}`;
}

/**
 * Builds plain text email body.
 */
function buildEmailBody_(urgent, high, others) {
  let body = 'Undone Task Reminder\n\n';

  if (urgent.length) {
    body += '🚨 URGENT TASKS\n';
    body += urgent.join('\n');
    body += '\n\n';
  }

  if (high.length) {
    body += '⚠️ HIGH PRIORITY TASKS\n';
    body += high.join('\n');
    body += '\n\n';
  }

  if (others.length) {
    body += '📌 OTHER TASKS\n';
    body += others.join('\n');
    body += '\n';
  }

  return body;
}

/**
 * Moves all rows with Status = Done from Tasks to Archive.
 * This runs only when you click it manually.
 */
function archiveAllCompletedTasks() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const tasks = ss.getSheetByName(CFG.TASKS_SHEET);
  const archive = ss.getSheetByName(CFG.ARCHIVE_SHEET);

  if (!tasks) throw new Error('Tasks sheet not found.');
  if (!archive) throw new Error('Archive sheet not found.');

  const lastRow = tasks.getLastRow();
  const lastCol = tasks.getLastColumn();

  if (lastRow < 2) {
    SpreadsheetApp.getUi().alert('No task rows found.');
    return;
  }

  const data = tasks.getRange(1, 1, lastRow, lastCol).getValues();
  const header = data[0];

  const rowsToKeep = [header];
  const rowsToArchive = [];

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const status = row[COL.STATUS - 1];

    if (status === CFG.STATUS_DONE) {
      if (!row[COL.COMPLETED_AT - 1]) {
        row[COL.COMPLETED_AT - 1] = new Date();
      }
      rowsToArchive.push(row);
    } else {
      rowsToKeep.push(row);
    }
  }

  if (rowsToArchive.length > 0) {
    archive.getRange(
      archive.getLastRow() + 1,
      1,
      rowsToArchive.length,
      rowsToArchive[0].length
    ).setValues(rowsToArchive);
  }

  tasks.clearContents();
  tasks.getRange(1, 1, rowsToKeep.length, rowsToKeep[0].length).setValues(rowsToKeep);

  setupDropdowns_(tasks);
  setupConditionalFormatting();

  SpreadsheetApp.getUi().alert(`${rowsToArchive.length} completed task(s) archived.`);
}

/**
 * Creates a daily time-driven trigger.
 * Deletes old trigger for same function first.
 */
function createDailyTrigger() {
  const settings = getSettings_();
  const hour = settings.dailyHour || 8;

  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(trigger => {
    if (trigger.getHandlerFunction() === 'sendDailySummaryEmail') {
      ScriptApp.deleteTrigger(trigger);
    }
  });

  ScriptApp.newTrigger('sendDailySummaryEmail')
    .timeBased()
    .everyDays(1)
    .atHour(hour)
    .create();

  SpreadsheetApp.getUi().alert(`Daily trigger created at about ${hour}:00.`);
}

/**
 * Deletes all project triggers.
 */
function deleteAllProjectTriggers() {
  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(trigger => ScriptApp.deleteTrigger(trigger));
  SpreadsheetApp.getUi().alert('All project triggers deleted.');
}

/**
 * Formats date for email.
 */
function formatDate_(value) {
  if (!(value instanceof Date)) return String(value || '');
  return Utilities.formatDate(value, Session.getScriptTimeZone(), 'yyyy-MM-dd');
}

    .addItem('3. Send Reminder Now', 'sendDailySummaryEmail')
    .addItem('4. Archive Completed Tasks', 'archiveAllCompletedTasks')
    .addItem('5. Create Daily Trigger', 'createDailyTrigger')
    .addItem('6. Delete All Triggers', 'deleteAllProjectTriggers')
    .addItem('7. Apply Formatting', 'setupConditionalFormatting')
    .addToUi();
}

/**
 * Creates sheets, headers, dropdowns, and formatting.
 */
function setupSystem() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const tasks = getOrCreateSheet_(ss, CFG.TASKS_SHEET);
  const archive = getOrCreateSheet_(ss, CFG.ARCHIVE_SHEET);
  const settings = getOrCreateSheet_(ss, CFG.SETTINGS_SHEET);

  setupTasksSheet_(tasks);
  setupArchiveSheet_(archive);
  setupSettingsSheet_(settings);
  setupDropdowns_(tasks);
  setupConditionalFormatting();

  SpreadsheetApp.getUi().alert('Task system setup complete.');
}

/**
 * Creates or gets a sheet by name.
 */
function getOrCreateSheet_(ss, name) {
  return ss.getSheetByName(name) || ss.insertSheet(name);
}

/**
 * Sets up Tasks sheet headers.
 */
function setupTasksSheet_(sheet) {
  const headers = [[
    'Task ID',
    'Task',
    'Category',
    'Owner Email',
    'Due Date',
    'Priority',
    'Status',
    'Reminder Sent',
    'Last Reminder',
    'Notes',
    'Created At',
    'Completed At'
  ]];

  sheet.clear();
  sheet.getRange(1, 1, 1, headers[0].length).setValues(headers);
  sheet.setFrozenRows(1);
  sheet.autoResizeColumns(1, headers[0].length);
}

/**

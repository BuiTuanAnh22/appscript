  };
}

function fillMissingTaskMetadata(){
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(CFG.TASKS_SHEET);
  const data = sheet.getRange(2,1,sheet.getLastRow()-1,COL.COMPLETED_AT).getValues();

  const now = new Date();

  for(let i=0;i<data.length;i++){
    const row = data[i];
    const r = i+2;

    if(row[COL.TASK-1] && !row[COL.ID-1]){
      sheet.getRange(r,COL.ID).setValue(createId());
    }
    if(row[COL.TASK-1] && !row[COL.CREATED_AT-1]){
      sheet.getRange(r,COL.CREATED_AT).setValue(now);
    }
    if(row[COL.TASK-1] && !row[COL.STATUS-1]){
      sheet.getRange(r,COL.STATUS).setValue('Undone');
    }
  }
}

function createId(){
  return Utilities.formatDate(new Date(), Session.getScriptTimeZone(),'yyyyMMdd-HHmmss');
}

/**
 * 🚀 OPTIMIZED EMAIL FUNCTION (BATCH VERSION)
 */
function sendDailySummaryEmail() {
  const settings = getSettings_();
  const emails = settings.email.split(',').map(e=>e.trim());

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(CFG.TASKS_SHEET);
  const data = sheet.getRange(2,1,sheet.getLastRow()-1,COL.COMPLETED_AT).getValues();

  const urgent=[], high=[], others=[];
  const reminderSentValues=[];
  const lastReminderValues=[];

  const now = new Date();
  let hasTasks=false;

  for(let i=0;i<data.length;i++){
    const row=data[i];

    const task=row[COL.TASK-1];
    const status=row[COL.STATUS-1];
    const priority=row[COL.PRIORITY-1];

    let sent=row[COL.REMINDER_SENT-1];
    let last=row[COL.LAST_REMINDER-1];

    if(task && status===CFG.STATUS_UNDONE){
      hasTasks=true;

      const line=`- ${task} | ${priority || ''}`;

      if(priority==='Urgent') urgent.push(line);
      else if(priority==='High') high.push(line);
      else others.push(line);

      sent='Yes';
      last=now;
    }

    reminderSentValues.push([sent]);
    lastReminderValues.push([last]);
  }

  if(!hasTasks) return;

  const body =
`TASK REMINDER

🚨 URGENT
${urgent.join('\n')}

⚠️ HIGH
${high.join('\n')}

📌 OTHERS
${others.join('\n')}
`;

  // ✅ ONLY 2 WRITES
  sheet.getRange(2,COL.REMINDER_SENT,reminderSentValues.length,1)
    .setValues(reminderSentValues);

  sheet.getRange(2,COL.LAST_REMINDER,lastReminderValues.length,1)
    .setValues(lastReminderValues);

  MailApp.sendEmail(emails.join(','),'Daily Tasks',body);
}

/**
 * Archive (already efficient)
 */
function archiveAllCompletedTasks(){
  const ss=SpreadsheetApp.getActiveSpreadsheet();
  const tasks=ss.getSheetByName(CFG.TASKS_SHEET);
  const archive=ss.getSheetByName(CFG.ARCHIVE_SHEET);

  const data=tasks.getDataRange().getValues();
  const header=data[0];

  const keep=[header];
  const move=[];

  for(let i=1;i<data.length;i++){
    const row=data[i];

    if(row[COL.STATUS-1]==='Done'){
      row[COL.COMPLETED_AT-1]=new Date();
      move.push(row);
    }else{
      keep.push(row);
    }
  }

  if(move.length){
    archive.getRange(archive.getLastRow()+1,1,move.length,move[0].length)
      .setValues(move);
  }

  tasks.clear();
  tasks.getRange(1,1,keep.length,keep[0].length).setValues(keep);
}

/**
 * Create daily trigger
 */
function createDailyTrigger(){
  const triggers=ScriptApp.getProjectTriggers();
  triggers.forEach(t=>{
    if(t.getHandlerFunction()==='sendDailySummaryEmail'){
      ScriptApp.deleteTrigger(t);
    }
  });

  const settings=getSettings_();

  ScriptApp.newTrigger('sendDailySummaryEmail')
    .timeBased()
    .everyDays(1)
    .atHour(settings.hour)
    .create();
}
